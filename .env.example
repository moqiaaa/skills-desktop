# Skills.lc API Configuration
# Copy this file to .env and fill in your values

# Full API endpoint URL (default: https://skills.lc/api/v1/skills/search)
VITE_SKILLS_API_URL=https://skills.lc/api/v1/skills/search

# API Key for authentication (get from https://skills.lc/api-keys)
# Format: sk_live_xxxxxxxxxxxxx
VITE_SKILLS_API_KEY=
